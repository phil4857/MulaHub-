<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Mkoba Wallet</title>
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background-color: #1c1e22;
      color: #eaeaea;
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      width: 220px;
      background: #111317;
      height: 100vh;
      padding: 1rem;
      position: fixed;
      top: 0;
      left: 0;
      display: flex;
      flex-direction: column;
    }

    .sidebar h2 {
      color: #f05454;
      margin-bottom: 2rem;
    }

    .sidebar button {
      background: none;
      border: none;
      color: #eaeaea;
      text-align: left;
      padding: 0.75rem 1rem;
      margin: 0.25rem 0;
      cursor: pointer;
      border-radius: 4px;
      transition: background 0.2s;
    }

    .sidebar button:hover {
      background: #2b2f36;
    }

    /* Main content */
    .main {
      margin-left: 240px;
      padding: 2rem;
      flex: 1;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      margin: 0;
      font-size: 1.5rem;
      color: #f05454;
    }

    .logout-btn {
      background: #f05454;
      border: none;
      color: #fff;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer;
    }

    #paymentBanner {
      margin-top: 10px;
      color: #ccc;
      font-style: italic;
    }

    /* User cards */
    .user-card {
      background: #2b2f36;
      border-radius: 8px;
      padding: 1rem;
      margin: 1rem 0;
      box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    }

    .user-card strong {
      color: #f1f1f1;
    }

    .user-card button {
      margin: 0.25rem;
      padding: 0.4rem 0.8rem;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.9rem;
    }

    .btn-approve { background: #28a745; color: white; }
    .btn-withdraw { background: #007bff; color: white; }
    .btn-reset { background: #ffc107; color: black; }
    .btn-term { background: #dc3545; color: white; }

    #searchInput {
      width: 100%;
      padding: 0.5rem;
      border-radius: 6px;
      border: none;
      margin-bottom: 1rem;
      background: #2b2f36;
      color: #eaeaea;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <h2>Admin Panel</h2>
    <button onclick="fetchUsers()">📋 Manage Users</button>
    <button onclick="logout()">🚪 Logout</button>
  </div>

  <div class="main">
    <header>
      <h1 id="dashboardTitle">Admin Dashboard</h1>
      <div>
        <span id="adminWelcome"></span>
        <button class="logout-btn" onclick="logout()">Logout</button>
      </div>
    </header>

    <div id="paymentBanner">Loading platform info...</div>

    <section>
      <h2>Registered Users</h2>
      <input id="searchInput" type="text" placeholder="🔍 Search user by name..." />
      <div id="userData">Loading users...</div>
    </section>
  </div>

  <!-- Ensure this matches your backend -->
  <script src="admin_dashboard.js"></script>
</body>
</html>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const REFRESH_INTERVAL = 8 * 60 * 1000; // every 8 minutes (before 10-min expiry)
  const backendUrl = "https://repo-1red-jipate-bonus.onrender.com";

  async function refreshAdminToken() {
    const token = localStorage.getItem("adminToken");
    if (!token) return;

    try {
      const res = await fetch(`${backendUrl}/admin/refresh`, {
        method: "POST",
        headers: { Authorization: `Bearer ${token}` },
      });

      if (!res.ok) {
        console.warn("Admin token refresh failed");
        localStorage.removeItem("adminToken");
        localStorage.removeItem("adminUsername");
        alert("Your admin session has expired. Please log in again.");
        window.location.href = "admin_login.html";
        return;
      }

      const data = await res.json();
      console.log("✅ Admin token refreshed:", new Date().toLocaleTimeString());
    } catch (err) {
      console.error("Error refreshing token:", err);
    }
  }

  // Run once on load and then periodically
  refreshAdminToken();
  setInterval(refreshAdminToken, REFRESH_INTERVAL);
});
</script>
