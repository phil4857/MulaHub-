<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Mkoba Wallet</title>
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background-color: #1c1e22;
      color: #eaeaea;
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      width: 220px;
      background: #111317;
      height: 100vh;
      padding: 1rem;
      position: fixed;
      top: 0;
      left: 0;
      display: flex;
      flex-direction: column;
    }

    .sidebar h2 {
      color: #f05454;
      margin-bottom: 2rem;
    }

    .sidebar button {
      background: none;
      border: none;
      color: #eaeaea;
      text-align: left;
      padding: 0.75rem 1rem;
      margin: 0.25rem 0;
      cursor: pointer;
      border-radius: 4px;
      transition: background 0.2s;
    }

    .sidebar button:hover {
      background: #2b2f36;
    }

    /* Main content */
    .main {
      margin-left: 240px;
      padding: 2rem;
      flex: 1;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      margin: 0;
      font-size: 1.5rem;
      color: #f05454;
    }

    .logout-btn {
      background: #f05454;
      border: none;
      color: #fff;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer;
    }

    #paymentBanner {
      margin-top: 10px;
      color: #ccc;
      font-style: italic;
    }

    /* User cards */
    .user-card {
      background: #2b2f36;
      border-radius: 8px;
      padding: 1rem;
      margin: 1rem 0;
      box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    }

    .user-card strong {
      color: #f1f1f1;
    }

    .user-card button {
      margin: 0.25rem;
      padding: 0.4rem 0.8rem;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.9rem;
    }

    .btn-approve { background: #28a745; color: white; }
    .btn-withdraw { background: #007bff; color: white; }
    .btn-reset { background: #ffc107; color: black; }
    .btn-term { background: #dc3545; color: white; }

    #searchInput {
      width: 100%;
      padding: 0.5rem;
      border-radius: 6px;
      border: none;
      margin-bottom: 1rem;
      background: #2b2f36;
      color: #eaeaea;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <h2>Admin Panel</h2>
    <button onclick="fetchUsers()">📋 Manage Users</button>
    <button onclick="logout()">🚪 Logout</button>
  </div>

  <div class="main">
    <header>
      <h1 id="dashboardTitle">Admin Dashboard</h1>
      <div>
        <span id="adminWelcome"></span>
        <button class="logout-btn" onclick="logout()">Logout</button>
      </div>
    </header>

    <div id="paymentBanner">Loading platform info...</div>

    <section>
      <h2>Registered Users</h2>
      <input id="searchInput" type="text" placeholder="🔍 Search user by name..." />
      <div id="userData">Loading users...</div>
    </section>
  </div>

  <script>
    const backendUrl = "https://repo-1red-jipate-bonus.onrender.com";

    document.addEventListener("DOMContentLoaded", () => {
      const token = localStorage.getItem("adminToken");
      const adminName = localStorage.getItem("adminUsername");
      if (!token) {
        alert("No admin session found. Please log in again.");
        window.location.href = "admin_login.html";
        return;
      }
      document.getElementById("adminWelcome").textContent = `Welcome, ${adminName || "Admin"}`;
      fetchPlatformInfo();
      fetchUsers();
      setupSearch();
      setInterval(refreshAdminToken, 8 * 60 * 1000);
    });

    async function refreshAdminToken() {
      const token = localStorage.getItem("adminToken");
      if (!token) return;
      try {
        const res = await fetch(`${backendUrl}/admin/refresh`, {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) {
          throw new Error("Token expired");
        }
        console.log("✅ Token refreshed", new Date().toLocaleTimeString());
      } catch {
        alert("Session expired. Please log in again.");
        logout();
      }
    }

    async function fetchPlatformInfo() {
      try {
        const res = await fetch(`${backendUrl}/platform/info`);
        const data = await res.json();
        document.getElementById("paymentBanner").textContent =
          `Payments via ${data.payment_number} (${data.platform})`;
      } catch {
        document.getElementById("paymentBanner").textContent = "Failed to load platform info.";
      }
    }

    async function fetchUsers() {
      const token = localStorage.getItem("adminToken");
      const userDataDiv = document.getElementById("userData");
      userDataDiv.textContent = "Loading users...";

      try {
        const res = await fetch(`${backendUrl}/admin/users`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (!res.ok) {
          if (res.status === 403 || res.status === 401) logout();
          throw new Error("Failed to fetch users");
        }
        const users = await res.json();
        renderUsers(users);
      } catch (err) {
        userDataDiv.textContent = "⚠️ Error fetching users.";
        console.error(err);
      }
    }

    function renderUsers(users) {
      const container = document.getElementById("userData");
      container.innerHTML = "";
      if (!users.length) {
        container.textContent = "No users found.";
        return;
      }

      for (const u of users) {
        const card = document.createElement("div");
        card.className = "user-card";
        card.innerHTML = `
          <strong>${u.username}</strong><br>
          Number: ${u.number}<br>
          Approved: ${u.approved ? "✅" : "❌"}<br>
          Balance: ${u.balance}<br>
          Earnings: ${u.earnings}<br>
          Principal: ${u.principal}<br>
          Referral: ${u.referral || "—"}<br>
          <button class="btn-approve" onclick="approveUser('${u.username}')">Approve</button>
          <button class="btn-term" onclick="terminateUser('${u.username}')">Terminate</button>
        `;
        container.appendChild(card);
      }
    }

    function setupSearch() {
      const input = document.getElementById("searchInput");
      input.addEventListener("input", () => {
        const query = input.value.toLowerCase();
        const cards = document.querySelectorAll(".user-card");
        cards.forEach(card => {
          card.style.display = card.innerText.toLowerCase().includes(query)
            ? "block"
            : "none";
        });
      });
    }

    async function approveUser(username) {
      const token = localStorage.getItem("adminToken");
      try {
        const form = new FormData();
        form.append("username", username);
        const res = await fetch(`${backendUrl}/admin/approve_user`, {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
          body: form,
        });
        if (!res.ok) throw new Error("Approval failed");
        alert(`✅ ${username} approved`);
        fetchUsers();
      } catch (err) {
        alert(err.message);
      }
    }

    async function terminateUser(username) {
      if (!confirm(`Are you sure you want to remove ${username}?`)) return;
      const token = localStorage.getItem("adminToken");
      try {
        const form = new FormData();
        form.append("username", username);
        const res = await fetch(`${backendUrl}/admin/terminate_user`, {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
          body: form,
        });
        if (!res.ok) throw new Error("Failed to terminate user");
        alert(`❌ ${username} deleted`);
        fetchUsers();
      } catch (err) {
        alert(err.message);
      }
    }

    function logout() {
      localStorage.removeItem("adminToken");
      localStorage.removeItem("adminUsername");
      window.location.href = "admin_login.html";
    }
  </script>
</body>
</html>
