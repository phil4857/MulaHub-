<h2>Admin Panel</h2>
<div id="userList"></div>
<script>
const BACKEND_URL = "https://your-backend-url";

async function loadUsers() {
    const username = localStorage.getItem('username'); // admin username
    try {
        const res = await fetch(`${BACKEND_URL}/admin/users?username=${username}`);
        if (!res.ok) throw new Error('Not authorized or server error');
        const data = await res.json();
        const container = document.getElementById('userList');
        container.innerHTML = '';
        data.users.forEach(u => {
            const div = document.createElement('div');
            div.innerHTML = `${u.username} - Approved: ${u.approved} 
                <button onclick="approve('${u.username}')">Approve</button>`;
            container.appendChild(div);
        });
    } catch (err) {
        alert(err.message);
    }
}

async function approve(usernameToApprove) {
    const username = localStorage.getItem('username');
    const res = await fetch(`${BACKEND_URL}/admin/approve/${usernameToApprove}?username=${username}`, {
        method: 'POST'
    });
    if (res.ok) {
        alert('User approved!');
        loadUsers();
    } else {
        const data = await res.json();
        alert(data.detail);
    }
}

loadUsers();
</script>
