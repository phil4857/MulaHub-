<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invest - Jipate Bonus</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(to bottom, #FFD700, #FFF8DC); /* gold tones */
      margin: 0;
      padding: 0;
    }

    header {
      background: #003366; /* dark blue */
      color: white;
      text-align: center;
      padding: 15px;
    }

    .container {
      max-width: 500px;
      margin: 30px auto;
      padding: 20px;
      background: white;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }

    h2 {
      margin-top: 0;
      color: #003366;
    }

    label {
      display: block;
      margin-bottom: 8px;
      margin-top: 15px;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      box-sizing: border-box;
    }

    button {
      margin-top: 20px;
      width: 100%;
      background: #003366;
      color: white;
      padding: 10px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }

    button:hover {
      background: #001f33;
    }

    .note {
      margin-top: 20px;
      font-size: 14px;
      color: #cc0000;
    }
  </style>
</head>
<body>

<header>
  <h1>Make an Investment</h1>
</header>

<div class="container">
  <h2>Invest in Jipate Bonus 💵🎉💸</h2>
  <form id="investForm">
    <label for="amount">Amount (KES):</label>
    <input type="number" id="amount" required />

    <label for="transactionRef">Transaction Reference:</label>
    <input type="text" id="transactionRef" required />

    <button type="submit">Submit Investment</button>

    <p class="note">
      NOTE: Send your payment via MPESA to <strong>0737734533</strong> before submitting.<br />
      Sunday investments receive a <strong>5% discount</strong> automatically.
    </p>
  </form>
</div>

<script>
  const username = localStorage.getItem("username");
  if (!username) {
    alert("Please log in first.");
    window.location.href = "login.html";
  }

  document.getElementById("investForm").addEventListener("submit", async function (e) {
    e.preventDefault();
    const amount = parseFloat(document.getElementById("amount").value);
    const transactionRef = document.getElementById("transactionRef").value;

    if (!amount || amount <= 0 || !transactionRef) {
      alert("Please enter valid details.");
      return;
    }

    const formData = new FormData();
    formData.append("username", username);
    formData.append("amount", amount);
    formData.append("transaction_ref", transactionRef);

    try {
      const res = await fetch("https://repo-1red-jipate-bonus.onrender.com/invest", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();
      alert(data.message || "Investment submitted.");
      window.location.href = "dashboard.html";
    } catch (err) {
      alert("Error submitting investment.");
    }
  });
</script>

</body>
</html>
