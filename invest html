<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invest - Jipate Bonus</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(to right, #ffd700, #1e3a5f); /* gold to navy blue */
      margin: 0;
      padding: 0;
      color: #333;
    }

    header {
      background-color: #1e3a5f;
      color: white;
      text-align: center;
      padding: 20px 0;
      box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }

    .container {
      max-width: 500px;
      margin: 50px auto;
      background-color: white;
      border-radius: 10px;
      padding: 30px;
      box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
    }

    h2 {
      margin-top: 0;
      color: #1e3a5f;
      text-align: center;
    }

    label {
      display: block;
      margin-bottom: 6px;
      margin-top: 20px;
      font-weight: bold;
    }

    input {
      width: 100%;
      padding: 12px;
      font-size: 16px;
      border: 1px solid #ccc;
      border-radius: 5px;
      margin-top: 5px;
      box-sizing: border-box;
    }

    button {
      width: 100%;
      margin-top: 25px;
      padding: 12px;
      font-size: 16px;
      background-color: #ffd700;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
      color: #1e3a5f;
    }

    button:hover {
      background-color: #e6c200;
    }

    .note {
      margin-top: 20px;
      font-size: 14px;
      color: #b30000;
    }

    .note strong {
      color: #1e3a5f;
    }

    footer {
      text-align: center;
      margin-top: 30px;
      color: white;
    }
  </style>
</head>
<body>

<header>
  <h1>Make an Investment</h1>
</header>

<div class="container">
  <h2>Invest in Jipate Bonus 💵🎉💸</h2>
  <form id="investForm">
    <label for="amount">Investment Amount (KES):</label>
    <input type="number" id="amount" required placeholder="e.g. 500"/>

    <label for="transactionRef">Transaction Reference:</label>
    <input type="text" id="transactionRef" required placeholder="MPESA code"/>

    <button type="submit">Submit Investment</button>

    <p class="note">
      <strong>NOTE:</strong> Please send payment via MPESA to <strong>0737734533</strong> before submitting this form.  
      Sunday investments automatically receive a 5% bonus.
    </p>
  </form>
</div>

<footer>
  &copy; 2025 Jipate Bonus Platform
</footer>

<script>
  const username = localStorage.getItem("username");
  if (!username) {
    alert("Please log in first.");
    window.location.href = "login.html";
  }

  document.getElementById("investForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const amount = parseFloat(document.getElementById("amount").value);
    const transactionRef = document.getElementById("transactionRef").value.trim();

    if (!amount || amount <= 0 || transactionRef === "") {
      alert("Please enter a valid amount and transaction reference.");
      return;
    }

    const formData = new FormData();
    formData.append("username", username);
    formData.append("amount", amount);
    formData.append("transaction_ref", transactionRef);

    try {
      const res = await fetch("https://repo-1red-jipate-bonus.onrender.com/invest", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.detail || "Failed to submit investment.");
      }

      alert(data.message || "Investment submitted successfully!");
      window.location.href = "dashboard.html";
    } catch (err) {
      console.error(err);
      alert("Error submitting investment. Please try again.");
    }
  });
</script>

</body>
</html>
