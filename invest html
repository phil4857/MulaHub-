<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invest - Jipate Bonus</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(to bottom, gold, #006699);
      margin: 0;
      padding: 0;
    }

    header {
      background: #004080;
      color: white;
      text-align: center;
      padding: 15px;
    }

    .container {
      max-width: 500px;
      margin: 30px auto;
      padding: 20px;
      background: white;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.2);
    }

    h2 {
      margin-top: 0;
      color: #004080;
      text-align: center;
    }

    label {
      display: block;
      margin-bottom: 8px;
      margin-top: 15px;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      box-sizing: border-box;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    button {
      margin-top: 20px;
      width: 100%;
      background: #004080;
      color: white;
      padding: 12px;
      font-size: 16px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    button:hover {
      background: #003366;
    }

    .note {
      margin-top: 20px;
      font-size: 14px;
      color: #cc0000;
      text-align: center;
    }

    .success {
      color: green;
    }
  </style>
</head>
<body>

<header>
  <h1>Make an Investment</h1>
</header>

<div class="container">
  <h2>Invest in Jipate Bonus 💵🎉💸</h2>
  <form id="investForm">
    <label for="amount">Amount (KES):</label>
    <input type="number" id="amount" min="100" required />

    <label for="transactionRef">Transaction Reference:</label>
    <input type="text" id="transactionRef" required />

    <button type="submit">Submit Investment</button>

    <p class="note">
      NOTE: Send your payment via MPESA to <strong>0737734533</strong> before submitting.<br/>
      Sunday investments automatically receive a 5% bonus.
    </p>
  </form>
</div>

<script>
  const username = localStorage.getItem("username");
  if (!username) {
    alert("Please log in first.");
    window.location.href = "login.html";
  }

  document.getElementById("investForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const amount = parseFloat(document.getElementById("amount").value);
    const transactionRef = document.getElementById("transactionRef").value.trim();

    if (!amount || amount <= 0 || !transactionRef) {
      alert("Please fill out all fields correctly.");
      return;
    }

    const formData = new FormData();
    formData.append("username", username);
    formData.append("amount", amount);
    formData.append("transaction_ref", transactionRef);

    try {
      const res = await fetch("https://repo-1red-jipate-bonus.onrender.com/invest", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.detail || "Investment failed.");
      }

      alert(data.message || "Investment submitted successfully.");
      window.location.href = "dashboard.html";

    } catch (err) {
      console.error(err);
      alert("Error submitting investment: " + (err.message || "Unknown error."));
    }
  });
</script>

</body>
</html>
