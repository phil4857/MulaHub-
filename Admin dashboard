<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Admin Dashboard</title>
<style>
body{font-family:Arial; padding:20px;}
table{width:100%; border-collapse:collapse; margin-top:20px;}
th,td{border:1px solid #ccc; padding:8px;}
button{padding:5px 8px;}
</style>
</head>
<body>

<h2>Admin Dashboard</h2>
<button onclick="logout()">Logout</button>

<h3>Users</h3>
<table>
<thead><tr><th>Username</th><th>Approved</th><th>Action</th></tr></thead>
<tbody id="users"></tbody>
</table>

<script>
const BACKEND_URL="https://repo-1red-jipate-bonus.onrender.com";
if(localStorage.getItem("admin")!=="true"){window.location="admin-login.html";}

async function loadUsers(){
const res=await fetch(`${BACKEND_URL}/admin/users`);
const data=await res.json();
users.innerHTML="";
data.forEach(u=>{
users.innerHTML+=`
<tr>
<td>${u.username}</td>
<td>${u.approved}</td>
<td>${!u.approved ? `<button onclick="approve('${u.username}')">Approve</button>`:""}</td>
</tr>
`;
});
}
loadUsers();

async function approve(username){
const formData=new URLSearchParams();
formData.append("username",username);

await fetch(`${BACKEND_URL}/admin/approve-user`,{
method:"POST",
headers:{"Content-Type":"application/x-www-form-urlencoded"},
body:formData
});
loadUsers();
}

function logout(){
localStorage.removeItem("admin");
window.location="admin-login.html";
}
</script>
</body>
</html>
