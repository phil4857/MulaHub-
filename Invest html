  <script>
    const commoditySelect = document.getElementById('commoditySelect');
    const amountInput = document.getElementById('amount');
    const investForm = document.getElementById('investForm');
    const investMessage = document.getElementById('investMessage');
    const countdownDisplay = document.getElementById('countdown');

    // Update the minimum investment based on selected commodity
    commoditySelect.addEventListener('change', function() {
      const selectedOption = this.options[this.selectedIndex];
      const minInvestment = selectedOption.getAttribute('data-min');
      amountInput.setAttribute('min', minInvestment);
      investMessage.textContent = `Minimum investment for ${selectedOption.textContent} is KES ${minInvestment}.`;
    });

    // Handle form submission
    investForm.addEventListener('submit', function(event) {
      event.preventDefault();
      const amount = amountInput.value;
      const txRef = document.getElementById('txRef').value;
      const selectedCommodity = commoditySelect.value;

      if (amount < commoditySelect.options[commoditySelect.selectedIndex].getAttribute('data-min')) {
        investMessage.textContent = 'Investment amount is below the minimum required.';
        return;
      }

      // Send investment data to the backend (replace with your API endpoint)
      fetch('/api/invest', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ amount, txRef, commodity: selectedCommodity })
      })
      .then(response => response.json())
      .then(data => {
        investMessage.textContent = data.message;
        startCountdown(); // Start the countdown for the earning period
      })
      .catch(error => {
        investMessage.textContent = 'Error processing investment.';
        console.error('Error:', error);
      });
    });

    // Countdown function
    function startCountdown() {
      const countdownEnd = new Date(Date.now() + 24 * 60 * 60 * 1000); // 24 hours from now
      const countdownInterval = setInterval(() => {
        const now = new Date();
        const remainingTime = countdownEnd - now;

        if (remainingTime < 0) {
          clearInterval(countdownInterval);
          countdownDisplay.textContent = 'Time to earn again!';
        } else {
          const hours = Math.floor((remainingTime % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((remainingTime % (1000 * 60 * 60)) / (1000 * 60));
          countdownDisplay.textContent = `Earnings available in: ${hours}h ${minutes}m`;
        }
      }, 60000); // Update every minute
    }

    // Cancel button functionality
    document.getElementById('cancelBtn').addEventListener('click', function() {
      investForm.reset();
      investMessage.textContent = '';
      countdownDisplay.textContent = '';
    });
  </script>
</body>
</html>
