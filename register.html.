        Verify OTP
    



document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('registerForm');
    const errorMsg = document.getElementById('errorMsg');
    const successMsg = document.getElementById('successMsg');
    const otpSection = document.getElementById('otpSection');
    const otpDisplay = document.getElementById('otpDisplay');
    const otpInput = document.getElementById('otpInput');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.textContent = '';
        successMsg.textContent = '';
        
        const formData = new FormData(form);
        const terms = formData.get('terms');
        
        if (!terms) {
            errorMsg.textContent = 'You must agree to the terms.';
            return;
        }

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData
            });

            if (!response.ok) {
                const errorDetails = await response.json();
                errorMsg.textContent = errorDetails.detail || 'Registration failed.';
                return;
            }

            otpDisplay.textContent = 'OTP has been sent to your phone.';
            otpSection.style.display = 'block';

        } catch (error) {
            console.error('Error:', error);
            errorMsg.textContent = 'An error occurred. Please try again later.';
        }
    });

    document.getElementById('verifyOtpBtn').addEventListener('click', async () => {
        const enteredOtp = otpInput.value.trim();
        if (!enteredOtp) {
            errorMsg.textContent = 'Enter OTP.';
            return;
        }

        try {
            const response = await fetch('http://localhost:8000/verify-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    username: document.getElementById('username').value.trim(),
                    otp: enteredOtp
                })
            });

            if (!response.ok) {
                const errorDetails = await response.json();
                errorMsg.textContent = errorDetails.detail || 'OTP verification failed.';
                return;
            }

            successMsg.textContent = 'Registration successful! Redirecting...';
            otpSection.style.display = 'none';

            setTimeout(() => {
                window.location.href = 'dashboard.html';
            }, 1500);

        } catch (error) {
            console.error('Error:', error);
            errorMsg.textContent = 'An error occurred. Please try again later.';
        }
    });
});
