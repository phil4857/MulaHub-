<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Mkoba Wallet - Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* Add your CSS styles here */
    </style>
</head>
<body>

<div class="register-container">
    <h2>Mkoba Wallet Registration</h2>
    <form id="registerForm">
        <input type="text" id="username" placeholder="Username" required>
        <input type="text" id="phone" placeholder="Phone (07XXXXXXXX)" required>
        <input type="password" id="password" placeholder="Password" required>
        <input type="password" id="confirmPassword" placeholder="Confirm Password" required>
        <input type="checkbox" id="terms"> I agree to the terms
        <button type="submit">Register</button>
        <div class="error-message" id="errorMsg"></div>
        <div class="success-message" id="successMsg"></div>
    </form>

    <div id="otpSection" style="display:none;">
        <p id="otpDisplay"></p>
        <input type="text" id="otpInput" placeholder="Enter OTP" required>
        <button id="verifyOtpBtn">Verify OTP</button>
    </div>
</div>

<script>
function togglePassword(id) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
}

document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('registerForm');
    const errorMsg = document.getElementById('errorMsg');
    const successMsg = document.getElementById('successMsg');
    const otpSection = document.getElementById('otpSection');
    const otpDisplay = document.getElementById('otpDisplay');
    const otpInput = document.getElementById('otpInput');

    function resetMessages() {
        errorMsg.textContent = '';
        successMsg.textContent = '';
        otpDisplay.textContent = '';
    }

    // ---------------- REGISTER ----------------
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        resetMessages();

        const username = document.getElementById('username').value.trim();
        const phone = document.getElementById('phone').value.trim();
        const password = document.getElementById('password').value;
        const confirm = document.getElementById('confirmPassword').value;
        const terms = document.getElementById('terms').checked;

        if (!terms) {
            errorMsg.textContent = 'You must agree to the terms.';
            return;
        }

        if (!/^[0-9]{10}$/.test(phone)) {
            errorMsg.textContent = 'Invalid phone number.';
            return;
        }

        if (!/^[a-zA-Z0-9_]{3,15}$/.test(username)) {
            errorMsg.textContent = 'Username must be 3-15 letters, numbers, or underscores.';
            return;
        }

        if (password.length < 6) {
            errorMsg.textContent = 'Password must be at least 6 characters.';
            return;
        }

        if (password !== confirm) {
            errorMsg.textContent = 'Passwords do not match.';
            return;
        }

        try {
            const response = await fetch('http://localhost:8000/register', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    username: username,
                    phone: phone,
                    password: password
                })
            });

            if (!response.ok) {
                const errorDetails = await response.json();
                errorMsg.textContent = errorDetails.detail || 'Registration failed.';
                return;
            }

            otpDisplay.textContent = 'OTP has been sent to your phone.';
            otpSection.style.display = 'block';

        } catch (error) {
            console.error('Error:', error);
            errorMsg.textContent = 'An error occurred. Please try again later.';
        }
    });

    // ---------------- VERIFY OTP ----------------
    document.getElementById('verifyOtpBtn').addEventListener('click', async () => {
        resetMessages();

        const enteredOtp = otpInput.value.trim();
        if (!enteredOtp) {
            errorMsg.textContent = 'Enter OTP.';
            return;
        }

        try {
            const response = await fetch('http://localhost:8000/verify-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    username: document.getElementById('username').value.trim(),
                    otp: enteredOtp
                })
            });

            if (!response.ok) {
                const errorDetails = await response.json();
                errorMsg.textContent = errorDetails.detail || 'OTP verification failed.';
                return;
            }

            successMsg.textContent = 'Registration successful! Redirecting...';
            otpSection.style.display = 'none';

            setTimeout(() => {
                window.location.href = 'dashboard.html';
            }, 1500);

        } catch (error) {
            console.error('Error:', error);
            errorMsg.textContent = 'An error occurred. Please try again later.';
        }
    });
});
</script>

</body>
</html>
