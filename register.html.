<script>
function togglePassword(id) {
  const input = document.getElementById(id);
  input.type = input.type === "password" ? "text" : "password";
}

let fakeOTP = null;

document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("registerForm");
  const errorMsg = document.getElementById("errorMsg");
  const successMsg = document.getElementById("successMsg");
  const otpSection = document.getElementById("otpSection");
  const otpDisplay = document.getElementById("otpDisplay");
  const otpInput = document.getElementById("otpInput");

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    errorMsg.textContent = "";
    successMsg.textContent = "";
    otpDisplay.textContent = "";

    const username = document.getElementById("username").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const password = document.getElementById("password").value;
    const confirm = document.getElementById("confirmPassword").value;
    const terms = document.getElementById("terms").checked;

    if (!terms) return errorMsg.textContent = "You must agree to terms.";
    if (!/^[0-9]{10}$/.test(phone)) return errorMsg.textContent = "Invalid phone number.";
    if (!/^[a-zA-Z0-9_]{3,15}$/.test(username)) return errorMsg.textContent = "Username must be 3-15 letters, numbers or underscores.";
    if (password.length < 6) return errorMsg.textContent = "Password must be at least 6 characters.";
    if (password !== confirm) return errorMsg.textContent = "Passwords do not match.";

    const users = JSON.parse(localStorage.getItem("users") || "{}");
    if (users[username]) {
      return errorMsg.textContent = "Username already exists.";
    }

    // Generate fake OTP
    fakeOTP = Math.floor(100000 + Math.random() * 900000).toString();

    otpDisplay.textContent = "Your OTP: " + fakeOTP;
    otpSection.style.display = "block";
    successMsg.textContent = "OTP generated. Enter it below to complete registration.";

    localStorage.setItem("pendingRegistration", JSON.stringify({
      username,
      phone,
      password
    }));
  });

  document.getElementById("verifyOtpBtn").addEventListener("click", () => {

    errorMsg.textContent = "";
    successMsg.textContent = "";

    const enteredOtp = otpInput.value.trim();

    if (!enteredOtp) return errorMsg.textContent = "Enter OTP.";
    if (enteredOtp !== fakeOTP) return errorMsg.textContent = "Incorrect OTP.";

    const pending = JSON.parse(localStorage.getItem("pendingRegistration"));
    if (!pending) return errorMsg.textContent = "Registration session expired.";

    const users = JSON.parse(localStorage.getItem("users") || "{}");

    users[pending.username] = {
      username: pending.username,
      phone: pending.phone,
      password: pending.password,
      balance: 10000,
      earnings: 0,
      verified: true,
      investments: {}
    };

    localStorage.setItem("users", JSON.stringify(users));
    localStorage.setItem("username", pending.username);
    localStorage.removeItem("pendingRegistration");

    successMsg.textContent = "Registration successful! Redirecting...";
    otpSection.style.display = "none";

    setTimeout(() => {
      window.location.href = "dashboard.html";
    }, 1500);
  });

});
</script>
