<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Register - Mkoba Wallet</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body {font-family: Arial; background:#f4f4f4; display:flex; justify-content:center; align-items:center; height:100vh;}
.box {background:white; padding:30px; width:320px; border-radius:8px; box-shadow:0 5px 15px rgba(0,0,0,0.2);}
input,button {width:100%; padding:10px; margin-top:10px;}
button {background:#28a745; color:white; border:none; cursor:pointer;}
button:hover {background:#218838;}
.msg {margin-top:10px; font-size:14px;}
</style>
</head>
<body>

<div class="box">
<h2>Register</h2>
<input id="username" placeholder="Username">
<input id="phone" placeholder="Phone">
<input id="password" type="password" placeholder="Password">
<input id="referral" placeholder="Referral (optional)">
<button onclick="register()">Register</button>
<div class="msg" id="msg"></div>
<p>Already have account? <a href="login.html">Login</a></p>
</div>

<script>
const BACKEND_URL = "https://repo-1red-jipate-bonus.onrender.com";

async function register(){
const msg = document.getElementById("msg");
msg.innerText = "";

const formData = new URLSearchParams();
formData.append("username", username.value);
formData.append("phone", phone.value);
formData.append("password", password.value);
formData.append("referral", referral.value);

const res = await fetch(`${BACKEND_URL}/register`,{
method:"POST",
headers:{"Content-Type":"application/x-www-form-urlencoded"},
body:formData
});

const data = await res.json();
msg.innerText = data.message || data.detail;

if(res.ok){
msg.style.color="green";
}else{
msg.style.color="red";
}
}
</script>
</body>
</html>
