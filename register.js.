document.addEventListener('DOMContentLoaded', () => {

  const form = document.getElementById('registerForm');
  const otpSection = document.getElementById('otpSection');
  const otpInput = document.getElementById('otpInput');
  const verifyBtn = document.getElementById('verifyOtpBtn');
  const errorMsg = document.getElementById('errorMsg');
  const successMsg = document.getElementById('successMsg');
  const otpDisplay = document.getElementById('otpDisplay');

  let verificationKey = null;

  function resetMessages() {
    errorMsg.textContent = '';
    successMsg.textContent = '';
  }

  function showOTPSection() {
    otpSection.style.display = 'block';
  }

  function hideOTPSection() {
    otpSection.style.display = 'none';
  }

  // ---------------- REGISTER ----------------
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    resetMessages();
    otpDisplay.textContent = '';

    const username = document.getElementById('username').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const password = document.getElementById('password').value;
    const confirm = document.getElementById('confirmPassword').value;
    const referralInput = document.getElementById('referral');
    const referral = referralInput ? referralInput.value.trim() : '';

    if (!username || !phone || !password || !confirm) {
      errorMsg.textContent = 'Please fill in all required fields.';
      return;
    }

    if (!/^[a-zA-Z0-9_]{3,15}$/.test(username)) {
      errorMsg.textContent = 'Username must be 3–15 letters, numbers, or underscores.';
      return;
    }

    if (!/^07\d{8}$/.test(phone)) {
      errorMsg.textContent = 'Phone must be 07XXXXXXXX format.';
      return;
    }

    if (password.length < 6) {
      errorMsg.textContent = 'Password must be at least 6 characters.';
      return;
    }

    if (password !== confirm) {
      errorMsg.textContent = 'Passwords do not match.';
      return;
    }

    try {
      const response = await fetch('http://localhost:8000/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams({
          username: username,
          phone: phone,
          password: password,
          referral: referral
        })
      });

      if (!response.ok) {
        const errorDetails = await response.json();
        errorMsg.textContent = errorDetails.detail || 'Registration failed';
        return;
      }

      verificationKey = username;  // Store the username to verify OTP
      successMsg.textContent = `OTP sent to ${phone}.`;
      showOTPSection();

    } catch (error) {
      console.error('Error:', error);
      errorMsg.textContent = 'An error occurred. Please try again later.';
    }
  });

  // ---------------- VERIFY OTP ----------------
  verifyBtn.addEventListener('click', async () => {
    resetMessages();

    const enteredOTP = otpInput.value.trim();
    if (!enteredOTP) {
      errorMsg.textContent = 'Enter OTP to verify.';
      return;
    }

    try {
      const response = await fetch('http://localhost:8000/verify-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams({
          username: verificationKey,
          otp: enteredOTP
        })
      });

      if (!response.ok) {
        const errorDetails = await response.json();
        errorMsg.textContent = errorDetails.detail || 'OTP verification failed';
        return;
      }

      successMsg.textContent = 'Registration successful! Redirecting...';
      otpDisplay.textContent = '';
      hideOTPSection();

      setTimeout(() => {
        window.location.href = 'dashboard.html';
      }, 1500);

    } catch (error) {
      console.error('Error:', error);
      errorMsg.textContent = 'An error occurred. Please try again later.';
    }
  });

}); and OTP verification. Make sure your FastAPI server is running and accessible at `http://localhost:8000`, or adjust the URL accordingly if it's hosted elsewhere.
